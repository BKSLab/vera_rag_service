# --- База данных (Postgres) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_NAME=vera_rag_service
# POSTGRES_DB — читается напрямую образом postgres (не приложением) для
# создания БД при первом старте на пустом volume; должен совпадать с
# POSTGRES_NAME выше. Без него образ создаёт БД "postgres" (=POSTGRES_USER
# по умолчанию), а приложение падает с InvalidCatalogNameError.
POSTGRES_DB=vera_rag_service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

LOGGING_CONFIG_PATH=logging.ini

# --- Админка (sqladmin) ---
SECRET_KEY=your_secret_key_for_admin_sessions
ADMIN_LOGIN=admin
ADMIN_PASSWORD=your_admin_password
# В production за HTTPS-терминирующим reverse-proxy — обязательно true (ADM-7)
ADMIN_SESSION_HTTPS_ONLY=false

# --- Авторизация публичного REST API (X-API-Key, см. ARCH-1/API-1/SEC-1) ---
API_KEY=your_rag_service_api_key

# --- Qdrant (векторное хранилище) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=vera_kb

# --- Yandex Cloud (embeddings + LLM-обогащение чанков) ---
YANDEX_API_KEY=your_yandex_api_key
YANDEX_FOLDER_ID=your_yandex_folder_id
YANDEX_EMBEDDING_DOC_MODEL=text-embeddings-v2-doc
YANDEX_EMBEDDING_QUERY_MODEL=text-embeddings-v2-query
YANDEX_LLM_MODEL=your_yandex_llm_model
YANDEX_LLM_API_URL=https://ai.api.cloud.yandex.net/v1/chat/completions

# --- Polza AI (reranker — Этап 6, обогащение чанков — Этап 3 — OpenAI-совместимый агрегатор) ---
POLZA_API_KEY=your_polza_api_key
POLZA_ENRICHMENT_LLM_MODEL=google/gemini-3.1-flash-lite-preview
POLZA_RERANKER_LLM_MODEL=google/gemini-3.1-flash-lite-preview
POLZA_QUERY_EXPANSION_LLM_MODEL=google/gemini-3.1-flash-lite-preview
POLZA_LLM_API_URL=https://polza.ai/api/v1/chat/completions

# --- Запуск (entrypoint.sh, см. ARCH-9/ARCH-10) ---
# При переходе на несколько реплик — RUN_MIGRATIONS_ON_START=false везде,
# кроме отдельного однократного шага деплоя, применяющего миграции.
RUN_MIGRATIONS_ON_START=true
HYPERCORN_WORKERS=2

# --- Distributed tracing (без query/chunk content) ---
PHOENIX_ENABLED=true
PHOENIX_OTLP_ENDPOINT=http://localhost:6006/v1/traces
# Должно совпадать с Agent и MCP текущего окружения.
PHOENIX_PROJECT_NAME=vera-local
